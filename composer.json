{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "open-ai/openai-php-client",
    "description": "Community-Driven PHP SDK for OpenAi AI API Integration.",
    "keywords": [
        "OpenAi PHP SDK",
        "OpenAi AI API"
    ],
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/dependencies-packagist/openai-php-client",
    "authors": [
        {
            "name": "jundayw",
            "email": "jundayw@126.com"
        }
    ],
    "require": {
        "php": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "OpenAi\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
